#----------------------------------------------------------
# Supabase Environment Variables
#----------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

#----------------------------------------------------------
# Google OAuth (optional, for Supabase Auth)
#   Get these from https://console.cloud.google.com/apis/credentials
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

#----------------------------------------------------------
# Homepage countdown target — ISO-8601 datetime.
# Defaults to 2025-12-31T18:30:00+07:00 if unset.
# Public (NEXT_PUBLIC_*) because the countdown ticks client-side.
#----------------------------------------------------------
NEXT_PUBLIC_EVENT_START_DATETIME=2025-12-31T18:30:00+07:00
